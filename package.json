{
  "name": "@audiocodes/ac-bot-api",
  "version": "0.11.0",
  "type": "module",
  "description": "AudioCodes Bot API SDK",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "rimraf dist && tsc",
    "build:watch": "tsc --watch",
    "build:dashboard": "cd admin-dashboard && npm ci && npm run build",
    "build:all": "npm run build && npm run build:dashboard",
    "start": "node dist/webhook-server.js",
    "start:dev": "tsx src/webhook-server.ts",
    "hash-password": "tsx src/scripts/hash-password.ts",
    "seed-users": "tsx src/scripts/seed-users.ts",
    "format": "dprint fmt",
    "format:check": "dprint check",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "prepack": "npm run build"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/audiocodes/ac-bot-api.git"
  },
  "keywords": [
    "audiocodes",
    "bot",
    "api",
    "sdk"
  ],
  "author": "AudioCodes Ltd",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/audiocodes/ac-bot-api/issues"
  },
  "homepage": "https://github.com/audiocodes/ac-bot-api#readme",
  "devDependencies": {
    "@dprint/typescript": "^0.96.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/bcrypt": "^6.0.0",
    "@types/debug": "^4.1.13",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.13.2",
    "@types/ws": "^8.18.1",
    "dprint": "^0.54.0",
    "globals": "^17.6.0",
    "oxlint": "^1.70.0",
    "oxlint-tsgolint": "^0.23.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@azure/identity": "^4.13.1",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "bcrypt": "^6.0.0",
    "debug": "^4.4.3",
    "eventemitter2": "^6.4.9",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  }
}
