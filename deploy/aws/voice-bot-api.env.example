# HTTP/API
PORT=8080

# SIP
SIP_PORT=5060
SIP_TLS_ENABLED=true
SIP_TLS_PORT=5061
SIP_TLS_CERT_PATH=/etc/ssl/voicebot/voicebot.crt
SIP_TLS_KEY_PATH=/etc/ssl/voicebot/voicebot.key
SRTP_ENABLED=false

# Auth
JWT_SECRET=PUT_LONG_RANDOM_SECRET_HERE
ADMIN_USERNAME=superadmin
ADMIN_PASSWORD_HASH=PUT_BCRYPT_HASH_HERE

# Integrations
CONFIG_openRouterApiKey=PUT_OPENROUTER_KEY
CONFIG_speechKey=PUT_AZURE_SPEECH_KEY
CONFIG_speechRegion=eastasia
CONFIG_tenantId=PUT_TENANT_ID
CONFIG_clientId=PUT_CLIENT_ID
CONFIG_clientSecret=PUT_CLIENT_SECRET
