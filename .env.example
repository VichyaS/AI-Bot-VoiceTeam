# ────────────────────────────────────────────────────────────
# VoiceTeam Bot Admin — Environment Configuration
# ────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ────────────────────────────────────────────────────────────

# ── JWT ────────────────────────────────────────────────────
# Secret key used to sign JSON Web Tokens.
# Generate a strong random key:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-random-secret

# ── Admin Authentication ───────────────────────────────────
# After running `npm run seed-users`, user credentials are stored
# in users.json. The ADMIN_USERNAME / ADMIN_PASSWORD_HASH env vars
# are still supported as a fallback for single-user setups.

# ── Server ─────────────────────────────────────────────────
PORT=8081

# ── OpenRouter AI ──────────────────────────────────────────
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ── Microsoft Entra ID (Azure AD) ──────────────────────────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
# Optional: ISO date when the client secret expires (e.g. 2026-12-31)
# AZURE_SECRET_EXPIRY_DATE=
# Optional: Filter users by domain suffix (e.g. @company.com)
# AZURE_SEARCH_SCOPE=

# ── Optional: Single-user fallback ─────────────────────────
# If you don't use the seed-based multi-user system, set these:
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD_HASH=$2b$10$...
# ADMIN_ROLE=SUPER_ADMIN